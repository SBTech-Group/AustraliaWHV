# ── Supabase (projeto PRÓPRIO do produto — hzaaqnbhhdpwfvtmuwkc) ──────────────
VITE_SUPABASE_URL=https://hzaaqnbhhdpwfvtmuwkc.supabase.co
VITE_SUPABASE_ANON_KEY=  # anon key do projeto novo (Dashboard > Settings > API)

# ── App ──────────────────────────────────────────────────────────────────────
VITE_PRODUCT_PRICE=R$ 49,90          # exibido na landing page
VITE_APP_URL=https://australia-whv.com  # URL pública do app (sem barra no final)

# ── Supabase Secrets (setar via: supabase secrets set KEY=value NO PROJETO NOVO) ─
# Nunca usar prefixo VITE_ nestas variáveis — não devem ir para o frontend.
#
# SUPABASE_SERVICE_ROLE_KEY=...       (já disponível nas Edge Functions)
# SUPABASE_URL=...                    (já disponível nas Edge Functions)
#
# MP_ACCESS_TOKEN=...                 # Mercado Pago Access Token
# MP_WEBHOOK_SECRET=...               # (recomendado) segredo p/ validar assinatura do webhook MP
# PRODUCT_PRICE=49.90                 # Preço em float para o MP (sem R$)
# APP_URL=https://australia-whv.com   # URL do app (back_urls + mensagem de boas-vindas)
#
# EVOLUTION_API_URL=...               # Instância Evolution PRÓPRIA do produto (ver nota de ban/escala)
# EVOLUTION_API_KEY=...
