# ── Supabase (mesmo projeto do Admin Hub) ────────────────────────────────────
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# ── App ──────────────────────────────────────────────────────────────────────
VITE_PRODUCT_PRICE=R$ 49,90          # exibido na landing page
VITE_APP_URL=https://australia-whv.com  # URL pública do app (sem barra no final)

# ── Supabase Secrets (setar via: supabase secrets set KEY=value) ─────────────
# Nunca usar prefixo VITE_ nestas variáveis — não devem ir para o frontend.
#
# SUPABASE_SERVICE_ROLE_KEY=...       (já disponível nas Edge Functions)
# SUPABASE_URL=...                    (já disponível nas Edge Functions)
#
# MP_ACCESS_TOKEN=...                 # Mercado Pago Access Token (produção ou sandbox)
# PRODUCT_PRICE=49.90                 # Preço em float para o MP (sem R$)
# APP_URL=https://australia-whv.com   # URL do app (para back_urls e mensagem de boas-vindas)
#
# EVOLUTION_API_URL=...               # Reusa do Admin Hub
# EVOLUTION_API_KEY=...               # Reusa do Admin Hub
